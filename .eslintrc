{
  "plugins": [
    "@vitest"
  ],
  "extends": [
    "eslint:recommended",
    "plugin:@vitest/legacy-recommended",
    "prettier"
  ],
  "env": {
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-cond-assign": [
      "error",
      "except-parens"
    ],
    "no-plusplus": [
      "error",
      {
        "allowForLoopAfterthoughts": true
      }
    ],
    "prefer-destructuring": "off"
  },
  "overrides": [
    {
      "files": ["tests/**/*.js"],
      "env": {
        "@vitest/env": true
      }
    }
  ]
}
